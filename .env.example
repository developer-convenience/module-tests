# ── 로컬 개발 ──────────────────────────────────────────────

# 토스페이먼츠 테스트 키 (개발자센터 > API 키)
# 클라이언트 키 — 프론트엔드 (test_ck_ 로 시작)
VITE_TOSS_CLIENT_KEY=test_ck_여기에_클라이언트_키

# 시크릿 키 — 백엔드 전용 (test_sk_ 로 시작, 절대 프론트에 넣지 마세요)
TOSS_SECRET_KEY=test_sk_여기에_시크릿_키

# 결제 승인 API 서버 포트 (선택)
PORT=3001

# Supabase (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 관리자 페이지 비밀번호
ADMIN_PASSWORD=change-me

# ── 배포 (Netlify 프론트 + Render API) ─────────────────────

# Render API URL — Netlify 환경변수에만 설정 (로컬은 비워 두고 Vite 프록시 사용)
# VITE_API_BASE_URL=https://leather-shop-api.onrender.com

# Netlify 사이트 URL — Render 환경변수에만 설정 (쉼표로 여러 도메인 가능)
# ALLOWED_ORIGINS=https://your-site.netlify.app
